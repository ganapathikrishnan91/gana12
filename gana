echo 'Hello world'
docker pull image-path
docker run -d --restart on-failure -v /var/run/docker.sock:/var/run/docker.sock:ro -v /etc/qualys:/usr/local/qualys/qpa/data/conf/agent-data -v /usr/local/qualys/sensor/data:/usr/local/qualys/qpa/data -e ACTIVATIONID= -e CUSTOMERID= -e POD_URL= --net=host --name qualys-container-sensor qualys/qcs-sensor:latest --cicd-deployed-sensor --log-level 5 --perform-sca-scan
sleep 60
echo "Checking Images are created (or) not "
docker images
echo "Checking Qualys Container sensor is running (or) not "
docker ps -a
echo " Give sometime to qualys to scan the image "
export IMAGE_ID=$(docker images --no-trunc --quiet mtaru/java-app)
echo "IMAGE_ID=$IMAGE_ID"
docker tag iamge-name:tag qualys_scan_target:$IMAGE_ID
cat /usr/local/qualys/sensor/data/logs/qpa.log
sleep 600
egrep -ai -n 'Scan started for docker image|Scan completed successfully for docker image|Upload Changelist success for docker image|Scanning failed for docker image' /usr/local/qualys/sensor/data/logs/qpa.log
export IMAGE_ID=$(docker images --no-trunc --quiet iamge-name)
